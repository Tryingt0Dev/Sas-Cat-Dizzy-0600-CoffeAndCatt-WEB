generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                       String                   @id @default(cuid())
  email                    String                   @unique
  name                     String
  passwordHash             String
  role                     String                   @default("USER")
  saasTheme                String                   @default("violet-premium")
  themeOnboardingCompleted Boolean                  @default(false)
  emailVerifiedAt          DateTime?
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @updatedAt
  auditLogs                AuditLog[]
  businesses               Business[]
  emailVerificationTokens  EmailVerificationToken[]
  memberships              Membership[]
  sessions                 Session[]
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EmailVerificationToken {
  id          String    @id @default(cuid())
  userId      String
  tokenHash   String    @unique
  expiresAt   DateTime
  consumedAt  DateTime?
  requestIp   String?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Business {
  id                     String                @id @default(cuid())
  ownerId                String
  planId                 String?
  planType               String                @default("normal")
  name                   String
  dashboardTitle         String?
  dashboardSubtitle      String?
  slug                   String                @unique
  publicSlug             String                @unique
  description            String?
  logoUrl                String?
  bannerUrl              String?
  catalogTemplate        String                @default("MODERN_GRID")
  primaryColor           String                @default("#111827")
  secondaryColor         String                @default("#F9FAFB")
  accentColor            String                @default("#E11D48")
  backgroundColor        String                @default("#F8FAFC")
  textColor              String                @default("#111827")
  catalogPalette         String                @default("minimal-arena")
  buttonRadius           Int                   @default(18)
  whatsappNumber         String?
  instagramUrl           String?
  businessType           String?
  address                String?
  welcomeMessage         String?
  seoTitle               String?
  seoDescription         String?
  seoKeywords            String?
  showFeaturedCategories Boolean               @default(true)
  showFeaturedProducts   Boolean               @default(true)
  currency               String                @default("CLP")
  isActive               Boolean               @default(true)
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  customDomain           String?               @unique
  customDomainVerified   Boolean               @default(false)
  aiSettings             AiSettings?
  auditLogs              AuditLog[]
  owner                  User                  @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  plan                   Plan?                 @relation(fields: [planId], references: [id])
  slugHistory            BusinessSlugHistory[]
  categories             Category[]
  conversations          Conversation[]
  customers              Customer[]
  memberships            Membership[]
  orders                 Order[]
  products               Product[]
  quotes                 Quote[]
  subscription           Subscription?

  @@index([ownerId])
  @@index([planId])
  @@index([publicSlug, isActive])
}

model Membership {
  id         String   @id @default(cuid())
  userId     String
  businessId String
  role       String   @default("STORE_OWNER")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, businessId])
  @@index([businessId])
  @@index([userId])
}

model BusinessSlugHistory {
  id         String   @id @default(cuid())
  businessId String
  slug       String   @unique
  createdAt  DateTime @default(now())
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
}

model AuditLog {
  id           String    @id @default(cuid())
  userId       String?
  businessId   String?
  action       String
  resourceType String
  resourceId   String?
  metadata     String?
  ip           String?
  userAgent    String?
  createdAt    DateTime  @default(now())
  business     Business? @relation(fields: [businessId], references: [id])
  user         User?     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([businessId])
  @@index([action])
  @@index([createdAt])
}

model Plan {
  id                        String         @id @default(cuid())
  type                      String         @unique
  name                      String
  description               String         @default("")
  maxProducts               Int
  maxImages                 Int            @default(100)
  maxCategories             Int            @default(10)
  maxAiConversationsMonthly Int
  maxUsers                  Int
  maxMembers                Int            @default(1)
  maxStores                 Int            @default(1)
  maxTemplates              Int
  aiEnabled                 Boolean        @default(true)
  advancedBranding          Boolean        @default(false)
  advancedSeoEnabled        Boolean        @default(false)
  analyticsEnabled          Boolean        @default(false)
  pageBuilderEnabled        Boolean        @default(false)
  advancedAttributesEnabled Boolean        @default(false)
  quotesAndOrders           Boolean        @default(false)
  customDomain              Boolean        @default(false)
  supportLevel              String         @default("community")
  createdAt                 DateTime       @default(now())
  updatedAt                 DateTime       @updatedAt
  businesses                Business[]
  subscriptions             Subscription[]
}

model Subscription {
  id                     String    @id @default(cuid())
  businessId             String    @unique
  planId                 String
  status                 String    @default("active")
  currentPeriodStart     DateTime  @default(now())
  currentPeriodEnd       DateTime?
  cancelAtPeriodEnd      Boolean   @default(false)
  provider               String?
  providerCustomerId     String?
  providerSubscriptionId String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  business               Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  plan                   Plan      @relation(fields: [planId], references: [id])

  @@index([planId])
  @@index([status])
  @@index([providerSubscriptionId])
}

model PlatformSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  isSecret    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([key])
}

model PlatformAdminAccess {
  id             String   @id @default(cuid())
  email          String   @unique
  role           String   @default("ADMIN")
  enabled        Boolean  @default(true)
  createdByEmail String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([email])
  @@index([role])
  @@index([enabled])
}

model Category {
  id         String    @id @default(cuid())
  businessId String
  name       String
  slug       String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  business   Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  products   Product[]

  @@unique([businessId, slug])
  @@index([businessId])
  @@index([businessId, createdAt])
}

model Product {
  id                 String      @id @default(cuid())
  businessId         String
  categoryId         String?
  name               String
  slug               String
  sku                String?
  description        String?
  price              Int
  compareAtPrice     Int?
  costPrice          Int?
  discountPercent    Int         @default(0)
  stock              Int         @default(0)
  minStock           Int         @default(0)
  imageUrl           String?
  tags               String?
  attributesJson     String?
  variantsJson       String?
  status             String      @default("ACTIVE")
  featured           Boolean     @default(false)
  aiConsultCount     Int         @default(0)
  productViewCount   Int         @default(0)
  whatsappClickCount Int         @default(0)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  orderItems         OrderItem[]
  business           Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  category           Category?   @relation(fields: [categoryId], references: [id])
  quoteItems         QuoteItem[]

  @@unique([businessId, slug])
  @@index([businessId])
  @@index([businessId, sku])
  @@index([businessId, categoryId])
  @@index([businessId, status])
  @@index([categoryId])
  @@index([status])
}

model Customer {
  id            String         @id @default(cuid())
  businessId    String
  name          String?
  phone         String?
  email         String?
  source        String?
  status        String         @default("NEW")
  leadScore     Int            @default(0)
  notes         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  conversations Conversation[]
  business      Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  orders        Order[]
  quotes        Quote[]

  @@index([businessId])
  @@index([phone])
  @@index([email])
  @@index([status])
}

model Conversation {
  id            String    @id @default(cuid())
  businessId    String
  customerId    String?
  channel       String    @default("WEBCHAT")
  status        String    @default("OPEN")
  visitorId     String?
  lastMessageAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  business      Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer      Customer? @relation(fields: [customerId], references: [id])
  messages      Message[]
  quotes        Quote[]

  @@index([businessId])
  @@index([customerId])
  @@index([visitorId])
  @@index([status])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderType     String
  content        String
  metadata       String?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

model Quote {
  id             String        @id @default(cuid())
  businessId     String
  customerId     String?
  conversationId String?
  status         String        @default("DRAFT")
  subtotal       Int           @default(0)
  discount       Int           @default(0)
  total          Int           @default(0)
  validUntil     DateTime?
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  order          Order?
  business       Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  conversation   Conversation? @relation(fields: [conversationId], references: [id])
  customer       Customer?     @relation(fields: [customerId], references: [id])
  items          QuoteItem[]

  @@index([businessId])
  @@index([customerId])
  @@index([conversationId])
  @@index([status])
}

model QuoteItem {
  id        String   @id @default(cuid())
  quoteId   String
  productId String?
  name      String
  quantity  Int
  unitPrice Int
  subtotal  Int
  product   Product? @relation(fields: [productId], references: [id])
  quote     Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
}

model Order {
  id         String      @id @default(cuid())
  businessId String
  customerId String?
  quoteId    String?     @unique
  status     String      @default("PENDING")
  subtotal   Int         @default(0)
  discount   Int         @default(0)
  total      Int         @default(0)
  notes      String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  business   Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer   Customer?   @relation(fields: [customerId], references: [id])
  quote      Quote?      @relation(fields: [quoteId], references: [id])
  items      OrderItem[]

  @@index([businessId])
  @@index([customerId])
  @@index([status])
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  productId String?
  name      String
  quantity  Int
  unitPrice Int
  subtotal  Int
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product? @relation(fields: [productId], references: [id])
}

model AiSettings {
  id                  String   @id @default(cuid())
  businessId          String   @unique
  tone                String   @default("profesional y cercano")
  instructions        String?
  fallbackMessage     String   @default("No tengo esa informacion exacta en el catalogo. Te puedo derivar con una persona del equipo.")
  allowAutoLead       Boolean  @default(true)
  humanHandoffEnabled Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  business            Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}
