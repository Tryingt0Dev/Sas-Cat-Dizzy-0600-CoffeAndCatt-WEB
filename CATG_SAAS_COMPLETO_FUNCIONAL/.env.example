# PostgreSQL database for local development, staging or production.
# Copy this file to `.env` and replace the credentials before running Prisma.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/catg_omniventas?schema=public"

# If using Supabase, Railway, Neon or another PostgreSQL provider, paste the
# provider connection string in DATABASE_URL.

# DeepSeek/OpenAI-compatible API settings. Use placeholders only.
DEEPSEEK_API_KEY="replace-with-your-deepseek-api-key"
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_MODEL="deepseek-chat"

# Public app URL used by metadata and future provider callbacks.
NEXT_PUBLIC_APP_URL="https://your-domain.example"
APP_URL="https://your-domain.example"
# Transactional email provider settings.
RESEND_API_KEY=""
EMAIL_FROM="no-reply@your-domain.example"
EMAIL_VERIFICATION_TOKEN_TTL_MINUTES="60"
CLEANUP_UNVERIFIED_HOURS="72"
# Cloudflare Turnstile anti-bot keys.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""
# Comma-separated dev origins (used only in non-production builds). Example: my-tunnel.trycloudflare.com
NEXT_ALLOWED_DEV_ORIGINS=""
# Comma-separated allowed origins for Server Actions (can be bare hosts or full origins). Values are normalized by the app.
NEXT_SERVER_ACTION_ALLOWED_ORIGINS=""
# Additional allowed request origins (comma-separated). Can be bare hostnames (example.com) or full origins (https://example.com).
REQUEST_ALLOWED_ORIGINS="https://your-domain.example"
# CSP examples - adjust to your providers. Keep data: and blob: if using local uploads or data URLs.
CSP_IMG_SRC="'self' data: blob: https:"
CSP_CONNECT_SRC="'self' https:"

# Optional private bootstrap secret for scripted/admin-only PLATFORM_ADMIN creation via registration action.
# Use a long random value, keep empty for public signup.
ADMIN_BOOTSTRAP_SECRET=""

# Platform owner fallback for /platform-admin. Database access entries are managed from the platform admin panel.
PLATFORM_OWNER_EMAILS="felipebustamante003@gmail.com"
PLATFORM_ADMIN_EMAILS=""
# Optional comma-separated owner/developer emails for unlocking plan limits in development only.
PLATFORM_OWNER_EMAILS_DEV_UNLOCK="false"

# Optional production rate limit backend. Without these values, local memory buckets are used.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
