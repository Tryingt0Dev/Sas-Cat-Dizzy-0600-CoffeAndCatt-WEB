{
  "name": "catg-omniventas-saas",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -H 0.0.0.0",
    "dev:network": "next dev -H 0.0.0.0",
    "dev:webpack": "next dev --webpack -H 0.0.0.0",
    "dev:local": "next dev",
    "build": "next build",
    "start": "next start -H 0.0.0.0",
    "lint": "eslint . --ext .ts,.tsx,.js --max-warnings=20",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:plans && npm run test:security",
    "test:plans": "tsx scripts/plan-smoke.ts",
    "test:security": "tsx scripts/security-smoke.ts",
    "test:ai-origin": "tsx scripts/ai-origin-smoke.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset-admins": "tsx scripts/reset-admin-users.ts",
    "setup": "prisma generate && prisma migrate dev --name init && tsx prisma/seed.ts",
    "reset": "prisma migrate reset --force && tsx prisma/seed.ts",
    "clean:next": "node -e \"require('fs').rmSync('.next', { recursive: true, force: true }); console.log('.next removed')\"",
    "cleanup:windows": "node scripts/cleanup.js",
    "diagrams:all": "node scripts/generate-diagrams.mjs"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@types/qrcode": "^1.5.6",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "next": "^16.2.6",
    "openai": "^4.104.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.25.76"
  },
  "overrides": {
    "postcss": "^8.5.15"
  },
  "devDependencies": {
    "@mermaid-js/mermaid-cli": "^11.15.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.19.11",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.22.0",
    "eslint-config-next": "^16.2.6",
    "postcss": "^8.5.15",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
