# PostgreSQL database for local development, staging or production.
# Copy this file to `.env` and replace the credentials before running Prisma.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/catg_omniventas?schema=public"

# If using Supabase, Railway, Neon or another PostgreSQL provider, paste the
# provider connection string in DATABASE_URL.

# DeepSeek/OpenAI-compatible API settings. Use placeholders only.
DEEPSEEK_API_KEY="replace-with-your-deepseek-api-key"
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_MODEL="deepseek-chat"

# ─────────────────────────────────────────────────────────────
# URL publica actual de la app. Define el dominio que se usa para
# generar links de verificacion de email, redirects de OAuth y
# metadata del sitio.
#
# En local puro (sin Cloudflared):
APP_URL="http://localhost:3000"
AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
#
# Con Cloudflared (la URL cambia cada vez que reinicias el tunel):
# APP_URL="https://xxxxx.trycloudflare.com"
# AUTH_URL="https://xxxxx.trycloudflare.com"
# NEXT_PUBLIC_APP_URL="https://xxxxx.trycloudflare.com"
#
# En produccion con dominio real:
# APP_URL="https://tudominio.com"
# AUTH_URL="https://tudominio.com"
# NEXT_PUBLIC_APP_URL="https://tudominio.com"
#
# Si no configuras APP_URL, la app deriva la URL automaticamente
# desde los headers del request (x-forwarded-proto + host).
# Esto funciona con Cloudflared sin necesidad de configurar la URL.
# ─────────────────────────────────────────────────────────────

# Trusted origins usados para server actions, form submissions y validacion de API.
# En local:
TRUSTED_ORIGINS="http://localhost:3000"
#
# Con Cloudflared:
# TRUSTED_ORIGINS="http://localhost:3000,https://xxxxx.trycloudflare.com"
#
# Produccion:
# TRUSTED_ORIGINS="https://tudominio.com"
#
# NEXT_SERVER_ACTION_ALLOWED_ORIGINS acepta dominios sin esquema:
# NEXT_SERVER_ACTION_ALLOWED_ORIGINS="tudominio.com,xxxxx.trycloudflare.com"

# Solo para next dev + Cloudflared (sin https://):
# NEXT_ALLOWED_DEV_ORIGINS="xxxxx.trycloudflare.com"

# Origenes adicionales permitidos para requests (bare hosts o URLs completas):
REQUEST_ALLOWED_ORIGINS="http://localhost:3000"
# CSP examples - adjust to your providers. Keep data: and blob: if using local uploads or data URLs.
CSP_IMG_SRC="'self' data: blob: https:"
CSP_CONNECT_SRC="'self' https:"

# ─────────────────────────────────────────────────────────────
# Entorno de la aplicacion
# ─────────────────────────────────────────────────────────────
# "local" usa entrega de email por consola por defecto.
# "production" requiere configuracion explicita de email.
APP_ENV="local"

# ─────────────────────────────────────────────────────────────
# Email de verificacion
# ─────────────────────────────────────────────────────────────
# EMAIL_DELIVERY_MODE controla como se envian los correos:
#   "console"  → Imprime el link de verificacion en la terminal (desarrollo local).
#   "resend"   → Envia correo real via API de Resend (produccion).
#   "disabled" → No envia correos. Usar solo en pruebas.
# Si no se configura:
#   - En local (APP_ENV=local): usa "console".
#   - En produccion (APP_ENV=production) con RESEND_API_KEY: usa "resend".
#   - En produccion sin RESEND_API_KEY: usa "disabled" y emite error.
EMAIL_DELIVERY_MODE="console"

# Requerir verificacion de email para acceder a rutas privadas.
# "true" por defecto. Solo usar "false" en entornos de prueba.
EMAIL_VERIFICATION_REQUIRED="true"

# Clave API de Resend y remitente.
# IMPORTANTE: Usa un dominio verificado en Resend, NO un Gmail personal.
# Ejemplo: no-reply@tudominio.com
RESEND_API_KEY=""
EMAIL_FROM="no-reply@your-domain.example"
EMAIL_VERIFICATION_TOKEN_TTL_MINUTES="60"
CLEANUP_UNVERIFIED_HOURS="72"

# Cloudflare Turnstile anti-bot keys.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""
# Enable Turnstile captcha (true=on, false=off).
# In development, defaults to off. In production, defaults to on.
TURNSTILE_ENABLED="false"

# Optional private bootstrap secret for scripted/admin-only PLATFORM_ADMIN creation via registration action.
# Use a long random value, keep empty for public signup.
ADMIN_BOOTSTRAP_SECRET=""

# Platform owner fallback for /platform-admin. Database access entries are managed from the platform admin panel.
PLATFORM_OWNER_EMAILS="felipebustamante003@gmail.com"
PLATFORM_ADMIN_EMAILS=""
# Optional comma-separated owner/developer emails for unlocking plan limits in development only.
PLATFORM_OWNER_EMAILS_DEV_UNLOCK="false"

# Optional production rate limit backend. Without these values, local memory buckets are used.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
